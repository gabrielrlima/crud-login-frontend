# URL base da API do backend, consumida pelo cliente HTTP em src/lib/api-client.ts.
# Exposta ao bundle do cliente (prefixo NEXT_PUBLIC_) porque chamadas de auth
# (cadastro/login) partem do browser.
#
# Em desenvolvimento, o backend roda na porta 8080 do host (default abaixo caso
# a variável não seja definida).
NEXT_PUBLIC_API_URL=http://localhost:8080

# Client ID do GitHub OAuth App usado no login/cadastro social
# (SDD-023, seção "Decisão de arquitetura"), consumido por src/features/auth/services/github-oauth.ts
# para montar a URL de https://github.com/login/oauth/authorize.
#
# Exposto ao bundle do cliente (prefixo NEXT_PUBLIC_) de propósito: o Client ID
# de um OAuth App não é segredo (fica visível na própria URL de autorização).
# O Client Secret correspondente NUNCA é exposto ao front-end — vive só na
# configuração do backend (GithubOAuth__ClientSecret / .env, fora deste
# projeto de frontend), usado apenas na troca do `code` por token
# (POST /api/auth/login/github).
NEXT_PUBLIC_GITHUB_CLIENT_ID=
